{
  "hooks": {
    "PostCompact": [
      {
        "hooks": [
          {
            "command": "harn hook post-compact",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "harn hook tool",
            "type": "command"
          }
        ],
        "matcher": "Read|Edit|Write|MultiEdit|Bash|Glob|Grep|ListDir"
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "command": "harn hook session-end",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "harn hook stop",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "command": "harn hook subagent-stop",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "command": "harn hook task-completed",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "harn hook prompt",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ]
  }
}